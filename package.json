{
  "name": "fs-mod-assistant-community",
  "version": "5.2.0-preview.1",
  "description": "Community-maintained Farm Sim Mod Assistant",
  "main": "modAssist_main.js",
  "homepage": "https://github.com/Blacknight78/FSG_Mod_Assistant#readme",
  "keywords": [],
  "author": {
    "name": "FSG Modding",
    "email": "jtsage+datebox@gmail.com",
    "url": "https://www.fsgmodding.com/"
  },
  "contributors": [
    {
      "name": "Blacknight78",
      "url": "https://github.com/Blacknight78"
    }
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Blacknight78/FSG_Mod_Assistant/issues/"
  },
  "repository": "github:Blacknight78/FSG_Mod_Assistant",
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "yarn@3.5.1",
  "scripts": {
    "lang": "node ./test/fix-locale-files.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node ./test/test.js",
    "depends": "node ./test/outdated-deps.js",
    "generate-docs": "node_modules\\.bin\\jsdoc -c .jsdoc.json"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/eslint-parser": "^7.25.7",
    "ansi-colors": "^4.1.3",
    "clean-css": "^5.3.3",
    "deepl-node": "^1.14.0",
    "deepmerge": "^4.3.1",
    "docolatte": "^4.5.1",
    "electron": "^32.1.2",
    "electron-builder": "~25.0.6",
    "eslint": "^9.12.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^15.11.0",
    "html-validate": "^8.24.1",
    "jsdoc": "^4.0.3"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "archiver": "^7.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "fast-xml-parser": "^4.5.0",
    "glob": "^11.0.0",
    "node-stream-zip": "^1.15.0",
    "unzip-stream": "^0.3.4",
    "wasm-vips": "^0.0.10"
  },
  "build": {
    "appId": "com.blacknight78.fsmodassistant.community",
    "productName": "FS Mod Assistant Community",
    "publish": [
      {
        "provider": "github",
        "owner": "Blacknight78",
        "repo": "FSG_Mod_Assistant"
      }
    ],
    "files": [
      "!README.*",
      "!test/*",
      "!screen_shots/**",
      "!**/.vscode/*",
      "!.github/*",
      "!/dist/*",
      "!/docs/*",
      "!/img_src/*",
      "!/renderer/inc/src/*"
    ],
    "extraFiles": [
      "texconv.exe",
      "icon/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    }
  }
}
